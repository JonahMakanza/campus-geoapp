# Campus GeoApp — Environment Configuration
# Copy this file to .env and fill in your values

# Your server's IP address and port
# Replace 192.168.1.100 with your actual PC/server IP (run 'ipconfig' on Windows)
EXPO_PUBLIC_API_URL=http://192.168.1.100:3001

# For production deployment, use your hosted server URL:
# EXPO_PUBLIC_API_URL=https://your-server.com
