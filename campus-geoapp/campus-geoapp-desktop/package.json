{
  "name": "campus-geoapp-desktop",
  "version": "1.0.0",
  "description": "Campus GeoApp Desktop Client - UZ Asset Management",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win --x64",
    "build-win-ia32": "electron-builder --win --ia32",
    "build-linux": "electron-builder --linux",
    "build-mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.campus.geoapp",
    "productName": "Campus GeoApp",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.ico",
      "publisherName": "UZ GIS Lab"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "main.js",
      "icon.ico",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "electron": "^41.2.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron-builder": "^26.8.1"
  }
}
